      {
        "Property": "Formulas",
        "Category": "Formulas",
        "InvariantScript": "MainBackground = RGBA(31, 31, 31, 1);\r\nTextPrimary = RGBA(255, 255, 255, 1);\r\nTextSecondary = RGBA(204, 204, 204, 1);\r\nGrayButton = RGBA(189, 195, 199, 1);\r\nBorderGray = RGBA(234, 234, 234, 1);  //not used\r\nButtonPrimary = RGBA(52, 152, 219, 1); //not used\r\nButtonText = RGBA(255, 255, 255, 1);  //not used\r\nRedButton     = RGBA(243, 89, 70, 1);      // Stop Process, Emergency Stop\r\nBlueButton    = RGBA(83, 180, 204, 1);     // Temperature, Pressure, Material Feed\r\nYellowButton  = RGBA(248, 194, 46, 1);     // Pause, Maintenance\r\nGreenButton   = RGBA(44, 185, 149, 1);     // Start Process, Quality Check\r\nPurpleButton  = RGBA(176, 133, 204, 1);\r\nDarkBlue      = RGBA(83, 180, 204, 0.47);\r\nDarkGreen     = RGBA(44, 185, 149, 0.71);",
