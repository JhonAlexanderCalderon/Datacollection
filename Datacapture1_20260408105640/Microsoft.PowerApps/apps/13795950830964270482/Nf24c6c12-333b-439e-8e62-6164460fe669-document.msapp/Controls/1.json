      {
        "Property": "OnStart",
        "Category": "Behavior",
        "InvariantScript": "// ── 1. PRODUCT PARAMETERS ─────────────────────────────────────\nClearCollect(\n    colProducts,\n    'Product Parameters (Filling Line)'\n);\n\n// ── 2. WORK ORDERS (solo los pendientes/en curso) ─────────────\nClearCollect(\n    colWorkOrders,\n    Filter('Work Orders', Status = \"Scheduled\" || Status = \"In Progress\")\n);\nNotify(\"Registros cargados: \" & CountRows(colWorkOrders), NotificationType.Information)\n;\n// ── 3. STAFF ──────────────────────────────────────────────────\nClearCollect(\n    colStaff,\n    Staff\n);\n\n// ── 4. SESION ACTIVA (recuperar si habia algo en progreso) ────\nSet(varActiveSession,\n    LookUp('Active Sessions', Status.Value = \"In Progress\")\n);\n\n// ── 5. VARIABLES GLOBALES INICIALES ───────────────────────────\nSet(varJobID,        \"\");\nSet(varNumpad,       \"\");\nSet(varUnitsTotal,   0);\nSet(varRejectsTotal, 0);\nSet(varWeighInput,   \"\");\nSet(varUnitsInput,   \"\");\nSet(varRejectsInput, \"\");\nSet(varFailureCategory, \"\");\nSet(varFaultDetail,  \"\");\nSet(varLineStopped,  false);\nSet(varLineStopTime, Now());\nSet(varTotalDowntime, 0);\nSet(varSetupTime,    \"\");\n\n// ── 6. SI HAY SESION EN PROGRESO → RECUPERAR ESTADO ──────────\nIf(\n    !IsBlank(varActiveSession),\n    Set(varJobID,        varActiveSession.JobOrder);\n    Set(varUnitsTotal,   varActiveSession.UnitsProduced);\n    Set(varRejectsTotal, varActiveSession.Rejects);\n    Set(varTotalDowntime, varActiveSession.TotalDowntime_min)\n);\n\nClearCollect(colActiveSessions,\n    Filter('Active Sessions',\n        Status.Value = \"In Progress\" || Status.Value = \"Paused\"\n    )\n);\n\nSet(varSupervisorName, \"\");\nSet(varPinInputText, \"\")",
        "RuleProviderType": "User"
      },
